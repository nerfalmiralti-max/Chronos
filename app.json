{
  "expo": {
    "name": "Chronos",
    "slug": "chronos",
    "scheme": "chronos",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "ios": { "supportsTablet": true, "bundleIdentifier": "app.chronos.mobile" },
    "android": { "package": "app.chronos.mobile", "predictiveBackGestureEnabled": true },
    "web": { "output": "static" },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      ["expo-splash-screen", { "backgroundColor": "#F5F4F1", "imageWidth": 96 }]
    ],
    "experiments": { "typedRoutes": true, "reactCompiler": true }
  }
}
